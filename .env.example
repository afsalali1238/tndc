# NextDoorChef — Environment Variables
# Copy to .env.local and fill values. NEVER commit .env.local.

# ── Supabase (Dashboard → Settings → API) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nextdoorchef.com
# Local dev: NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Notes ───────────────────────────────────────────────────
# NEXT_PUBLIC_ = exposed to browser (safe for anon key + URL)
# No prefix    = server-side only (use for service role key)
# Leaflet + OpenStreetMap: NO API KEY needed
# WhatsApp wa.me links:    NO API KEY needed
